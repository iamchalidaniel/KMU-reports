# Next.js / Frontend environment (copy to .env.local)
# API (backend) URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# =============================================================================
# AI - Open Router (https://openrouter.ai)
# =============================================================================
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional: model ID (default: openai/gpt-4o-mini). Examples:
#   openai/gpt-4o-mini
#   google/gemini-2.0-flash-001
#   anthropic/claude-3-haiku
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional: for Open Router referrer
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# SENTRY - Error Monitoring (https://sentry.io)
# =============================================================================
# Create a Next.js project at sentry.io and paste your DSN here
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@o000000.ingest.sentry.io/0000000
# SENTRY_ORG=your-org
# SENTRY_PROJECT=kmu-reports-frontend
# SENTRY_AUTH_TOKEN=your-sentry-auth-token